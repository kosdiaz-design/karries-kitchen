# Copy to server/.env for local dev (or set in Railway env for prod)

# Node
NODE_ENV=development
PORT=3001

# Postgres — Railway provides DATABASE_URL automatically
DATABASE_URL=postgres://user:pass@localhost:5432/karries_kitchen

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Seed PINs (Karrie = user, Eric = admin). Both are hashed on boot.
PIN_KARRIE=
PIN_ERIC=
